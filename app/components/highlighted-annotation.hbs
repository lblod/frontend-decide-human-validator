{{! template-lint-disable no-at-ember-render-modifiers }}
<AuButton
  type="button"
  @skin="naked"
  class="highlighted-annotation"
  {{did-update this.resetShowInfo @annotation}}
  {{on "click" this.toggleShowInfo}}
>{{@text}}{{yield}}&nbsp;<AuIcon @icon={{this.icon}} @size="large" /><AuCard
    class={{concat "highlight-info " (if this.showInfo "visible")}}
    {{on-click-outside
      this.resetShowInfo
      exceptSelector=".highlighted-annotation"
    }}
    @shadow="true"
    {{align-callout @annotation}}
    as |c|
  >
    <c.content class="au-u-padding-small">
      <AuButton
        class="close-button"
        @skin="link-secondary"
        @icon="x"
        @hideText={{true}}
        {{on "click" this.resetShowInfo}}
      >Close</AuButton>
      <div class="au-u-margin-top-none">
        <AuHeading
          @level={{4}}
          @skin={{4}}
          class="au-u-muted au-u-margin-none"
        >Type</AuHeading>
        <AnnotationType @annotation={{@annotation}} />
      </div>
      <div class="au-u-margin-top-small">
        <AuHeading
          @level={{4}}
          @skin={{4}}
          class="au-u-muted au-u-margin-none"
        >Label</AuHeading>
        <div>{{@annotation.valueText}}</div>
      </div>
      {{#if @annotation.valueLink}}
        <div class="au-u-margin-top-small">
          <AuHeading
            @level={{4}}
            @skin={{4}}
            class="au-u-muted au-u-margin-none"
          >URI</AuHeading>
          <AuLinkExternal
            href={{@annotation.valueLink}}
            newTab={{true}}
            title={{@annotation.valueLink}}
            class="ellipsis"
          ><span
              class="au-u-1-1 max-width-100"
            >{{@annotation.valueLink}}</span></AuLinkExternal>
        </div>
      {{else if this.showNoUriWarning}}
        <div class="au-u-margin-top-small">
          <AuHeading
            @level={{4}}
            @skin={{4}}
            class="au-u-muted au-u-margin-none"
          >URI</AuHeading>
          <div class="au-u-muted au-u-italic">
            No URI was linked to this entity yet.
          </div>
        </div>
      {{/if}}
    </c.content>
  </AuCard></AuButton>